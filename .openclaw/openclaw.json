{
  "plugins": {
    "entries": {
      "ollama": {
        "enabled": true
      }
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.4.8",
    "lastTouchedAt": "2026-04-08T23:46:09.514Z"
  },
  "gateway": {
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    }
  },
  "agents": {
    "defaults": {
      "workspace": "/workspace",
      "model": {
        "primary": "ollama/llama3.1:8b"
      },
      "heartbeat": {
        "every": "5m",
        "target": "last",
        "lightContext": false
      }
    }
  },
  "models": {
    "providers": {
      "ollama": {
        "baseUrl": "http://ollama:11434",
        "api": "ollama",
        "models": [
          {
            "id": "llama3.1:8b",
            "name": "llama3.1:8b",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 32768
          }
        ]
      }
    }
  },
  "mcp": {
    "servers": {
      "archon": {
        "command": "python3",
        "args": [
          "/workspace/services/archon-mcp/server.py"
        ],
        "env": {
          "ARCHON_API_BASE_URL": "http://archon:8080",
          "ARCHON_API_TOKEN_FILE": "/home/node/.openclaw/mcp.token"
        }
      }
    }
  }
}
