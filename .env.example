# Core model routing
OPENCLAW_PRIMARY_MODEL=ollama/qwen3-coder:latest
OPENCLAW_CODEX_REVIEW_MODEL=openai-codex/gpt-5.4
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=qwen3-coder:latest

# Review cadence
REVIEW_INTERVAL_SECONDS=300
REVIEW_CRON=*/5 * * * *
REVIEW_TIMEZONE=UTC

# OpenClaw workspace and execution
OPENCLAW_WORKSPACE=/workspace
OPENCLAW_CONFIG_PATH=/workspace/.openclaw/openclaw.json
OPENCLAW_MESSAGE_PREFIX=[harness-openclaw]
OPENCLAW_REVIEW_TIMEOUT_SECONDS=300

# Replace this with the real OpenClaw CLI invocation in your environment.
# The harness substitutes {message}, {model}, and {config} before execution.
OPENCLAW_SKILL_RUN_CMD=python /app/mock_openclaw_runner.py --message "{message}" --model "{model}" --config "{config}"

# Archon control-plane
ARCHON_DB_PATH=/data/archon.sqlite3
ARCHON_API_BASE_URL=http://archon:8080
ARCHON_REVIEW_QUEUE=codex-review
ARCHON_REQUIRE_HUMAN_APPROVAL=true

# Service ports
ARCHON_PORT=8080
OPENCLAW_GATEWAY_PORT=8090
OLLAMA_PORT=11434

# Optional bootstrap behavior
OLLAMA_PULL_MODEL=true
