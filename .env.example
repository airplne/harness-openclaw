# Core models
OPENCLAW_WORKER_MODEL=ollama/qwen3-coder:latest
OPENCLAW_REVIEW_MODEL=openai-codex/gpt-5.4
OLLAMA_MODEL=qwen3-coder:latest
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_API_KEY=ollama-local

# OpenClaw gateway
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=change-me
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_CONFIG_DIR=./.data/openclaw-config
OPENCLAW_WORKSPACE_DIR=.
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Auth / provider setup
# Run bootstrap onboarding to populate OpenClaw auth profiles for Codex OAuth.
# The official Docker onboarding flow stores auth under ${OPENCLAW_CONFIG_DIR}.
OPENCLAW_ACCEPT_RISK=false

# Review cadence
REVIEW_CRON=*/5 * * * *
REVIEW_TIMEZONE=UTC
OPENCLAW_REVIEW_TIMEOUT_SECONDS=60
WORKER_POLL_SECONDS=15

# Archon control plane
ARCHON_PORT=8080
ARCHON_DB_PATH=/data/archon.sqlite3
ARCHON_REQUIRE_HUMAN_APPROVAL=true
ARCHON_REVIEW_QUEUE=codex-review
ARCHON_REVIEWER_API_URL=http://127.0.0.1:8092
ARCHON_WORKER_API_URL=http://127.0.0.1:8091

# Service ports
OLLAMA_PORT=11434
