# Core models
OPENCLAW_WORKER_MODEL=ollama/qwen3-coder:latest
OPENCLAW_REVIEW_MODEL=openai-codex/gpt-5.4
OLLAMA_MODEL=qwen3-coder:latest
OLLAMA_BASE_URL=http://ollama:11434

# OpenClaw runtime
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_CONFIG_DIR=./.data/openclaw-config
OPENCLAW_WORKSPACE_DIR=.

# Review cadence
REVIEW_CRON=*/5 * * * *
REVIEW_TIMEZONE=UTC
OPENCLAW_REVIEW_TIMEOUT_SECONDS=60
WORKER_POLL_SECONDS=15

# Archon control plane
ARCHON_PORT=8080
ARCHON_DB_PATH=/data/archon.sqlite3
ARCHON_REQUIRE_HUMAN_APPROVAL=true
ARCHON_REVIEW_QUEUE=codex-review

# Service ports
OLLAMA_PORT=11434
